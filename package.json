    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/chrome": "latest",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "latest",
    "vitest": "^4.1.8"
  }
}
